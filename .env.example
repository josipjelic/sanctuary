# Sanctuary environment template
# Copy to your local file:  cp .env.example .env
# .env is gitignored — never commit real keys.
# After `npx supabase login`, fill Supabase vars with:  pnpm run env:supabase

# =============================================================================
# Supabase (required for the app)
# https://supabase.com/dashboard → your project → Project Settings → API
#   - Project URL     → EXPO_PUBLIC_SUPABASE_URL
#   - anon public key → EXPO_PUBLIC_SUPABASE_ANON_KEY
# =============================================================================
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# =============================================================================
# OpenRouter (server-side only — Supabase Edge Functions, not the Expo app)
# https://openrouter.ai/keys
# Set in Supabase: supabase secrets set OPENROUTER_API_KEY=<your-key>
# Optional model overrides (defaults are in edge function code):
#   OPENROUTER_TRANSCRIPTION_MODEL, OPENROUTER_TOPIC_MODEL (or OPENROUTER_TAGGING_MODEL)
# Edge logs: optional OPENROUTER_LOG_JSON_MAX_CHARS (default ~6500 per field; max ~9000).
# Supabase hosted logs allow ≤10k chars per console line — full multi‑KiB JSON is truncated.
# Do not prefix with EXPO_PUBLIC_ and do not ship this in the mobile client.
# =============================================================================
OPENROUTER_API_KEY=
