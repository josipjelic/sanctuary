# Supabase — client-side (safe to expose in the mobile app)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# OpenRouter — server-side only.
# Used exclusively inside Supabase Edge Functions. Never expose this value in the mobile app
# or prefix it with EXPO_PUBLIC_. Add it as a Supabase project secret:
#   supabase secrets set OPENROUTER_API_KEY=<your-key>
OPENROUTER_API_KEY=
